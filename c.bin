.sune-primary-color, .news-date-circle span, span.edit-link a, .null-instagram-feed p a, .navigation.pagination a.prev:hover, .navigation.pagination a.next:hover, .breadcrumbs span.current, .error-page-content .error-text, a:hover, a:focus, a.active { color: #D83228; }.sune-primary-color-bg, .sune-btn, span.edit-link a:hover, .navigation.pagination .page-numbers.current, .navigation.pagination a.page-numbers:hover, .upcomming-event-item:hover .image span, .barfiller, .barfiller .tip, .barfiller .fill, .button-primary, button, input[type="button"], input[type="reset"], input[type="submit"] { background-color: #D83228; }.sune-events-calender #tribe-bar-form .tribe-bar-submit input[type="submit"], .sune-events-calender .tribe-events-calendar thead th, .sune-events-calender .tribe-events-calendar td.tribe-events-present div[id*="tribe-events-daynum-"], .sune-events-calender .tribe-events-calendar td.tribe-events-present div[id*="tribe-events-daynum-"] > a, .sune-events-calender #tribe_events_filters_wrapper input[type="submit"], .sune-events-calender  .tribe-events-button, #tribe-events .tribe-events-button, .sune-events-calender .tribe-events-button.tribe-inactive, .sune-events-calender #tribe-events .tribe-events-button:hover, .sune-events-calender .tribe-events-button:hover, .sune-events-calender .tribe-events-button.tribe-active:hover { background-color: #D83228; }.news-date-circle, span.edit-link a, .sune-testimonial #quote-carousel .carousel-indicators .active, .get-envolved-item:hover .envolped-top { border-color: #D83228; }.sune-secondary-color, .error-page-menu ul li a, .copy-right-text a, .collection-rate .fund .text, .collection-rate .accomplish .colorfull-progress-active .acc-text, .sune-team-member .sune-team-member-details .designation { color: #00A650; }.sune-secondary-color-bg, .event-counter .countdown-amount, .popular-tag ul li a:hover, .sune-events-calender .tribe-bar-views-inner, .sune-events-calender #tribe-bar-views .tribe-bar-views-list .tribe-bar-views-option a:hover, .sune-events-calender #tribe-bar-views .tribe-bar-views-list .tribe-bar-views-option a, .sune-events-calender  #tribe-events-content .tribe-events-calendar td.tribe-events-has-events, .sune-events-calender .tribe-events-day .tribe-events-day-time-slot h5 { background-color: #00A650; }.sune-comments-section-title, .sune-widget-area h4.widget-title, .popular-tag ul li a:hover { border-color: #00A650; }input[type="text"]:focus, input[type="email"]:focus, input[type="password"]:focus, textarea:focus, .form-control:focus, .get-envolved-item .envolped-top { border-color: #00A650; }.collection-rate .accomplish .colorfull-progress-active .circle-text { border-color: #00A650; color: #00A650; }.news-item:hover .read-more-icon { border-left-color: #D83228; }.barfiller .tip:after { border-color: #D83228 transparent;; }.get-envolved-item:hover .envolped-top .text:before{ background: rgba(216, 50, 40, 0.95); }.get-envolved-item .envolped-top .text:before{ background: rgba(0, 166, 80, 0.95); }
