%3A%22url%3A%2523%7C%7C%7C%22%2C%22icon_type%22%3A%22fontawesome%22%2C%22icon_fontawesome%22%3A%22fab%20fa-linkedin-in%22%2C%22icon_color%22%3A%22%23007bb6%22%7D%5D&#8221; name=&#8221;Ruth Sinkeler&#8221; designation=&#8221;PENNINGMEESTER&#8221; description=&#8221;Nam sollicitudin libero eu diam faucibus, sit amet hendrerit scelerisqususcipit.&#8221; image=&#8221;420&#8243; link=&#8221;url:%23|||&#8221; data_percent=&#8221;100&#8243; data_step=&#8221;2&#8243; data_bordersize=&#8221;5&#8243;][\/vc_column][\/vc_row][vc_row][vc_column][vc_column_text]<\/p>\n<p style=\"text-align: center;\">Leden: Marl\u00e8ne Gravenberch, Radjeni Nirmalsingh, Sharien Khedoe<\/p>\n<p>[\/vc_column_text][\/vc_column][\/vc_row][\/vc_section][vc_section full_width=&#8221;stretch_row_content&#8221; css=&#8221;.vc_custom_1490605457826{padding-top: 0px !important;padding-bottom: 0px !important;background-color: #fbbc05 !important;background-position: 0 0 !important;background-repeat: no-repeat !important;}&#8221;][vc_row css=&#8221;.vc_custom_1490165117931{padding-top: 0px !important;padding-bottom: 0px !important;}&#8221;][vc_column width=&#8221;1\/2&#8243; css=&#8221;.vc_custom_1490165173981{padding: 0px !important;}&#8221;][vc_single_image image=&#8221;411&#8243; img_size=&#8221;full&#8221; el_class=&#8221;sune-image-corner-shape-2&#8243; css=&#8221;.vc_custom_1490606522905{margin-bottom: 0px !important;}&#8221;][\/vc_column][vc_column width=&#8221;1\/2&#8243; css=&#8221;.vc_custom_1491994782306{margin-top: 55px !important;margin-bottom: 55px !important;padding-right: 30px !important;padding-left: 30px !important;}&#8221; offset=&#8221;vc_col-lg-4 vc_col-md-6&#8243;][vc_custom_heading text=&#8221;VRIJWILLIGER WORDEN&#8221; font_container=&#8221;tag:h3|font_size:34px|text_align:left|line_height:44px&#8221; use_theme_fonts=&#8221;yes&#8221;][vc_custom_heading text=&#8221;WILT U GRAAG ALS VRIJWILLIGER UW BIJDRAGE LEVEREN AAN AAN STICHTING PRASORO? STUUR ONS EEN BERICHT.&#8221; font_container=&#8221;tag:p|font_size:24px|text_align:left|color:%23ffffff|line_height:32px&#8221; use_theme_fonts=&#8221;yes&#8221;][vc_btn title=&#8221;BERICHT VERZENDEN&#8221; style=&#8221;custom&#8221; custom_background=&#8221;#000000&#8243; custom_text=&#8221;#ffffff&#8221; size=&#8221;lg&#8221; css=&#8221;.vc_custom_1703983654177{margin-top: 0px !important;margin-bottom: 0px !important;}&#8221; link=&#8221;url:https%3A%2F%2Fstichtingprasoro.com%2Fcontact-us%2F|title:Contact%20Us&#8221;][\/vc_column][\/vc_row][\/vc_section][vc_section full_width=&#8221;stretch_row&#8221; disable_element=&#8221;yes&#8221; css=&#8221;.vc_custom_1703981538758{padding-top: 80px !important;padding-bottom: 90px !important;}&#8221;][vc_row 0=&#8221;&#8221;][vc_column 0=&#8221;&#8221;][vc_custom_heading text=&#8221;WE ARE GOOD AT OUR SERVICE&#8221; font_container=&#8221;tag:p|font_size:20px|text_align:center|color:%23939393&#8243; google_fonts=&#8221;font_family:Roboto%3A100%2C100italic%2C300%2C300italic%2Cregular%2Citalic%2C500%2C500italic%2C700%2C700italic%2C900%2C900italic|font_style:700%20bold%20regular%3A700%3Anormal&#8221; css=&#8221;.vc_custom_1490608382501{margin-bottom: 0px !important;}&#8221;][vc_custom_heading text=&#8221;OUR TESTIMONIALS&#8221; font_container=&#8221;tag:h2|text_align:center&#8221; use_theme_fonts=&#8221;yes&#8221; css=&#8221;.vc_custom_1490608400685{margin-top: 0px !important;padding-bottom: 50px !important;}&#8221;][\/vc_column][\/vc_row][vc_row 0=&#8221;&#8221;][vc_column 0=&#8221;&#8221;][sune_testimonial testimonials=&#8221;%5B%7B%22name%22%3A%22Isalla%20Chrisna%22%2C%22review%22%3A%22In%20fermentum%20eros%20in%20orci%20blandit%20scelerisque%20id%20a%20nibh.%20Proin%20net%20dignissim%20nisi%20blandit%20sce.%22%2C%22image%22%3A%22421%22%2C%22text_color%22%3A%22%23666666%22%7D%2C%7B%22name%22%3A%22Isalla%20Chrisna%22%2C%22review%22%3A%22In%20fermentum%20eros%20in%20orci%20blandit%20scelerisque%20id%20a%20nibh.%20Proin%20net%20dignissim%20nisi%20blandit%20sce.%22%2C%22ima