{"id":880,"date":"2024-01-26T15:19:18","date_gmt":"2024-01-26T15:19:18","guid":{"rendered":"https:\/\/stichtingprasoro.com\/?p=880"},"modified":"2024-01-26T15:36:59","modified_gmt":"2024-01-26T15:36:59","slug":"overhandiging-cheque-door-newmont","status":"publish","type":"post","link":"https:\/\/stichtingprasoro.com\/2024\/01\/26\/overhandiging-cheque-door-newmont\/","title":{"rendered":"Overhandiging cheque door Newmont"},"content":{"rendered":"<p style=\"text-align: left;\"><img loading=\"lazy\" decoding=\"async\" class=\"size-medium wp-image-883 alignleft\" src=\"https:\/\/stichtingprasoro.com\/wp-content\/uploads\/2024\/01\/PHOTO-2023-12-14-10-32-21-225x300.jpg\" alt=\"\" width=\"225\" height=\"300\" srcset=\"https:\/\/stichtingprasoro.com\/wp-content\/uploads\/2024\/01\/PHOTO-2023-12-14-10-32-21-225x300.jpg 225w, https:\/\/stichtingprasoro.com\/wp-content\/uploads\/2024\/01\/PHOTO-2023-12-14-10-32-21-768x1024.jpg 768w, https:\/\/stichtingprasoro.com\/wp-content\/uploads\/2024\/01\/PHOTO-2023-12-14-10-32-21.jpg 960w\" sizes=\"auto, (max-width: 225px) 100vw, 225px\" \/><\/p>\n<p>&nbsp;<\/p>\n<p style=\"text-align: left;\">Op 14 december 2023 behoorde Stichting Prasoro tot 1 van de kindertehuizen die voor een cheque ter waarde van SRD30,000.00 mocht ontvangen! Onze dank aan Newmont!<\/p>\n<p>Deze genereuze geste van Newmont was speciaal bedoeld voor de kerstviering met de kinderen. De kinderen hebben een gezellige middag doorgebracht bij Chuck&#8217;E&#8217;Cheese.<\/p>\n<p>Ook hebben zij op 1ste en 2de kerstdag van extra heerlijke maaltijden en extra tractaties mogen genieten.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>&nbsp; Op 14 december 2023 behoorde Stichting Prasoro tot 1 van de kindertehuizen die voor een cheque ter waarde van SRD30,000.00 mocht ontvangen! Onze dank aan Newmont! Deze genereuze geste [&hellip;]<\/p>\n","protected":false},"author":3,"featured_media":0,"comment_status":"open","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"_jetpack_memberships_contains_paid_content":false,"footnotes":""},"categories":[15],"tags":[],"class_list":["post-880","post","type-post","status-publish","format-standard","hentry","category-nieuws"],"jetpack_featured_media_url":"","jetpack_sharing_enabled":true,"_links":{"self":[{"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/posts\/880","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/users\/3"}],"replies":[{"embeddable":true,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/comments?post=880"}],"version-history":[{"count":5,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/posts\/880\/revisions"}],"predecessor-version":[{"id":896,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/posts\/880\/revisions\/896"}],"wp:attachment":[{"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/media?parent=880"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/categories?post=880"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/stichtingprasoro.com\/wp-json\/wp\/v2\/tags?post=880"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}